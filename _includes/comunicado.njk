---
layout: base.njk
---
<section class="page-hero">
  <div class="container">
    <div class="breadcrumb"><a href="/">Inicio</a> / <a href="/comunicados.html">Comunicados</a> / {{ breadcrumb or title }}</div>
    <span class="eyebrow">Comunicado oficial</span>
    <h1>{{ title }}</h1>
  </div>
</section>

<section>
  <div class="container comunicado-detail">
    <a href="/comunicados.html" class="back-link">← Volver a comunicados</a>
    <span class="comunicado-tag">{{ category }}</span>
    <p class="meta-date">Publicado el {{ date | fechaLarga }}</p>
    <div class="content">
      {{ content | safe }}
    </div>
    <div class="share-row">¿Tienes información adicional sobre este asunto? <a href="/contacto.html">Escríbenos</a>.</div>
  </div>
</section>
